# Copy this to .env and fill in your values
# Never commit .env to version control

# Required secrets
MONARCH_TOKEN=your-monarch-token-here
GSHEET_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Config (customize to match your sheet and Monarch account)
GSHEET_SHEET_ID=your-google-sheet-id-from-url
GSHEET_TAB=PF Summary
GSHEET_LABEL=Indian PF
MONARCH_ACCOUNT_NAME=Zerodha
